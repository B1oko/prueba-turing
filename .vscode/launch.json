{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload"
            ],
            "jinja": true
        },
        {
            "name": "UI: Streamlit",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "ui/app.py",
                "--server.port",
                "8501"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "API_URL": "http://127.0.0.1:8000"
            },
            "jinja": true
        }
    ],
    "compounds": [
        {
            "name": "Streamlit + API",
            "configurations": [
                "API: FastAPI",
                "UI: Streamlit"
            ],
            "stopAll": true
        }
    ]
}