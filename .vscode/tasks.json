{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "dev: API",
            "type": "shell",
            "command": "uv run uvicorn src.main:app --host 127.0.0.1 --port 8000 --reload",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "uvicorn",
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "(Uvicorn running|Application startup complete)"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "mtg-dev"
            }
        }
    ]
}